module ca53_generic_ram   #(parameter addr_bits  = 4,  
                            parameter data_bits  = 8,  
                            parameter we_size    = 1,  
                            parameter reset      = 0,  
                            parameter reset_high = 0)  
(
  input                          clk,
  input  [addr_bits-1:0]         addr_i,
  output [data_bits-1:0]         rd_o,
  input  [data_bits-1:0]         wd_i,
  input                          cs_i,
  input                          ls_i,  
  input                          gwe_i,
  input  [data_bits/we_size-1:0] we_i
);

  arm_element_sp_ram_pa #(
    .ADDR_WIDTH    (addr_bits),
    .DATA_WIDTH    (data_bits),
    .MEMORY_DEPTH  (1 << addr_bits),
    .LANE_WIDTH    (we_size)
  ) u_arm_element_sp_ram_pa (
    .CLK             (clk),
    .RESETn          (1'b1),
`ifdef ARM_PA_MODE_ENABLE
    .VDDCE                  (                    ),
    .VDDPE                  (                    ),
    .VSSE                   (                    ),
    .PGEN                   (                    ),
    .RET1N                  (                    ),
    .RET2N                  (                    ),
    .PRDYN                  (                    ),
`endif
    .A               (addr_i),
    .Q               (rd_o),
    .D               (wd_i),
    .CEN             (~cs_i),
    .WEN             (~({data_bits/we_size{gwe_i}} & we_i))
  );

endmodule
