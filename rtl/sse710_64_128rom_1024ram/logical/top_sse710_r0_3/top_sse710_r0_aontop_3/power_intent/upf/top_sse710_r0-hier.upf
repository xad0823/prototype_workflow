upf_version 2.1
set_design_top top_sse710_r0_aontop_3
if {![info exists env(FUNCTIONAL_PASIM) ]} { set env(FUNCTIONAL_PASIM)  0 }
if {![info exists env(QUESTA_PA)        ]} { set env(QUESTA_PA)         0 }
if {![info exists env(LOGICAL_PATH)     ]} { set env(LOGICAL_PATH)      ../../logical }
if {![info exists env(FLAT_CPUS)        ]} { set env(FLAT_CPUS)         0 }

set logicalPath $env(LOGICAL_PATH)

set PD_AON_fwpcsm_path      "u_system_control_f0_aontop/u_ppu_aon/u_fwram_pcsm"

set PD_SYSTOP_path          "u_pd_systop"
set PD_SYSTOP_ppu_path      "u_system_control_f0_aontop/u_ppu_aon/u_systop_ppu"
set PD_SYSTOP_pcsm_path     "u_system_control_f0_aontop/u_ppu_aon/u_systop_pcsm"

set PD_CLUSTOP_path         "u_pd_systop/u_pd_clustop"
set PD_CLUSTOP_ppu_path     "u_pd_systop/u_pc_cpu_systop/u_clustop_ppu"
set PD_CLUSTOP_pcsm_path    "u_pck600_ppu_pcsm_sse710_clus"

set PD_EXTSYS0TOP_path      "u_pd_extsys0top"
set PD_EXTSYS0TOP_ppu_path  ""
set PD_EXTSYS0TOP_pcsm_path ""

set PD_EXTSYS1TOP_path      "u_pd_extsys1top"
set PD_EXTSYS1TOP_ppu_path  ""
set PD_EXTSYS1TOP_pcsm_path ""

set PD_DBGTOP_path          "u_pd_dbgtop_f0"
set PD_DBGTOP_ppu_path      "u_system_control_f0_aontop/u_ppu_aon/u_dbgtop_ppu"
set PD_DBGTOP_pcsm_path     "u_system_control_f0_aontop/u_ppu_aon/u_dbgtop_pcsm"

set PD_SECENCTOP_path       "u_pd_secenc_f1_top"
set PD_SECENCTOP_ppu_path   "u_secenc_f1_aontop/u_secenc_f1_aon/u_sec_pwr_ctrl/u_pck600_ppu_sse710_secenc"
set PD_SECENCTOP_pcsm_path  "u_secenc_f1_aontop/u_secenc_f1_aon/u_pck600_ppu_pcsm_sse710_secenc"

   
   
  set PD_CPU0_path            [lindex [lsearch -all -inline -regexp [find_objects u_pd_systop/u_pd_clustop/u_cpu_gic_socket -object_type inst -pattern *ca53_cpu* -transitive TRUE] {g_ca53_cpu[^0-9]+0[^0-9]+u_ca53_cpu$}] 0]
   
   
   
  set PD_CPU1_path            [lindex [lsearch -all -inline -regexp [find_objects u_pd_systop/u_pd_clustop/u_cpu_gic_socket -object_type inst -pattern *ca53_cpu* -transitive TRUE] {g_ca53_cpu[^0-9]+1[^0-9]+u_ca53_cpu$}] 0]
   
   
   
  set PD_CPU2_path            [lindex [lsearch -all -inline -regexp [find_objects u_pd_systop/u_pd_clustop/u_cpu_gic_socket -object_type inst -pattern *ca53_cpu* -transitive TRUE] {g_ca53_cpu[^0-9]+2[^0-9]+u_ca53_cpu$}] 0]
   
   
   
  set PD_CPU3_path            [lindex [lsearch -all -inline -regexp [find_objects u_pd_systop/u_pd_clustop/u_cpu_gic_socket -object_type inst -pattern *ca53_cpu* -transitive TRUE] {g_ca53_cpu[^0-9]+3[^0-9]+u_ca53_cpu$}] 0]
   
 

set PD_CPU0_ppu_path        u_pd_systop/u_pc_cpu_systop/u_core0_ppu 
set PD_CPU1_ppu_path        u_pd_systop/u_pc_cpu_systop/u_core1_ppu 
set PD_CPU2_ppu_path        u_pd_systop/u_pc_cpu_systop/u_core2_ppu 
set PD_CPU3_ppu_path        u_pd_systop/u_pc_cpu_systop/u_core3_ppu 

set PD_CPU0_pcsm_path       u_pd_systop/u_pc_cpu_systop/u_pck600_ppu_pcsm_sse710_core0 
set PD_CPU1_pcsm_path       u_pd_systop/u_pc_cpu_systop/u_pck600_ppu_pcsm_sse710_core1 
set PD_CPU2_pcsm_path       u_pd_systop/u_pc_cpu_systop/u_pck600_ppu_pcsm_sse710_core2 
set PD_CPU3_pcsm_path       u_pd_systop/u_pc_cpu_systop/u_pck600_ppu_pcsm_sse710_core3 

puts "CPUS:"
puts " 0: $PD_CPU0_path"
puts " 1: $PD_CPU1_path"
puts " 2: $PD_CPU2_path"
puts " 3: $PD_CPU3_path"

puts "PCSMs:"
puts " 0: $PD_CPU0_pcsm_path"
puts " 1: $PD_CPU1_pcsm_path"
puts " 2: $PD_CPU2_pcsm_path"
puts " 3: $PD_CPU3_pcsm_path"

set PD_AON_mem              [lsearch -all -inline -regexp [find_objects u_system_control_f0_aontop/u_firewall_f0_ctlr -object_type inst -pattern *u_arm_element_sp_ram_pa* -transitive TRUE] {RAM_SRE1.*u_firewall_f0_sram/[^/]*u_arm_element_sp_ram_pa}]

set PD_CLUSTOP_l2_mem       [lsearch -all -inline -regexp [find_objects $PD_CLUSTOP_path -object_type inst -pattern *u_arm_element_sp_ram_pa* -transitive TRUE] {u_l2_.*ram.*/u_arm_element_sp_ram_pa[^/]*}]
 
 
set PD_CLUSTOP_scu_mem      [lsearch -all -inline -regexp [find_objects $PD_CLUSTOP_path -object_type inst -pattern *u_arm_element_sp_ram_pa* -transitive TRUE] {u_ca53scu_l1d_tagrams/.*/u_arm_element_sp_ram_pa}]
 
set PD_CLUSTOP_mem          [concat $PD_CLUSTOP_l2_mem $PD_CLUSTOP_scu_mem]

set PD_SECENCTOP_mem        [lsearch -all -inline -regexp [find_objects $PD_SECENCTOP_path -object_type inst -pattern *u_arm_element_sp_ram_pa* -transitive TRUE] {u_sec_mem_integration/.*u_arm_element_sp_ram_pa[^/]*}]
set PD_SECENCTOP_rom        [lsearch -all -inline -regexp [find_objects $PD_SECENCTOP_path -object_type inst -pattern *u_arm_element_sp_rom_pa* -transitive TRUE] {u_sec_mem_integration/.*u_arm_element_sp_rom_pa[^/]*}]



puts "###########################################################################"
puts "## PD_CLUSTOP RAMS:"
foreach ram [concat $PD_CLUSTOP_mem] {
  puts "## $ram"
}
puts "###########################################################################"

puts "###########################################################################"
puts "## INFO: PD_SYSTOP_path        $PD_SYSTOP_path      "
puts "## INFO: PD_SYSTOP_ppu_path    $PD_SYSTOP_ppu_path  "
puts "###########################################################################"
puts ""


#-------------------------------------------------------------------------------
# List of output ports to be clamped 1
#-------------------------------------------------------------------------------

# Clamp high for PD_SYSTOP signals
set PD_SYSTOP_ClampHigh [list \
    $PD_SYSTOP_path/aclk_on_syspll_divratio_cur\[4\] \
    $PD_SYSTOP_path/aclk_on_syspll_divratio_cur\[3\] \
