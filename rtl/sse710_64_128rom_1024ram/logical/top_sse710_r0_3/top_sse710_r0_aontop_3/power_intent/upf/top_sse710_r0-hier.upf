#-------------------------------------------------------------------------------
# Report clamp high settings
#-------------------------------------------------------------------------------
set power_domains {
    PD_CLUSTOP
    PD_SYSTOP
    PD_EXTSYS0TOP
    PD_EXTSYS1TOP
    PD_DBGTOP
    PD_SECENCTOP
    PD_CPU0 
    PD_CPU1 
    PD_CPU2 
    PD_CPU3 
}

puts "Isolate high ports:"
foreach domain $power_domains {
    puts "  $domain"
    foreach target_port [set ${domain}_ClampHigh] {
        puts "    $target_port"
    }
    if {$domain eq "PD_SYSTOP"} {
      foreach clamp_rule {PD_SYSTOP_CPU_PCSMs_ClampHigh} {
        puts "  $clamp_rule"
        foreach target_port [set $clamp_rule] {
          puts "    $target_port"
        }
      }
   }
}
puts ""

