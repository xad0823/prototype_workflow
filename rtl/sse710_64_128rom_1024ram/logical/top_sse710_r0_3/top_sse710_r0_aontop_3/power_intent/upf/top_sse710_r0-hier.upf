    $PD_SYSTOP_path/hostcpuclk_div1_clkdiv_cur\[1\] \
    $PD_SYSTOP_path/hostcpuclk_div1_clkdiv_cur\[0\] \
    $PD_SYSTOP_path/ctrlclk_on_syspll_divratio_cur\[4\] \
    $PD_SYSTOP_path/ctrlclk_on_syspll_divratio_cur\[3\] \
    $PD_SYSTOP_path/ctrlclk_on_syspll_divratio_cur\[2\] \
    $PD_SYSTOP_path/ctrlclk_on_syspll_divratio_cur\[1\] \
    $PD_SYSTOP_path/ctrlclk_on_syspll_divratio_cur\[0\] \
    $PD_SYSTOP_path/gicclk_div0_clkdiv_cur\[4\] \
    $PD_SYSTOP_path/gicclk_div0_clkdiv_cur\[3\] \
    $PD_SYSTOP_path/gicclk_div0_clkdiv_cur\[2\] \
    $PD_SYSTOP_path/gicclk_div0_clkdiv_cur\[1\] \
    $PD_SYSTOP_path/gicclk_div0_clkdiv_cur\[0\] \
    $PD_SYSTOP_path/debug_hostcpu_flush_done \
    $PD_SYSTOP_path/debug_hostcpu_sync_clear \
    $PD_SYSTOP_path/clustop_ppuhwstat\[0\] \
    $PD_SYSTOP_path/bready_xnvm_axim \
    $PD_SYSTOP_path/rready_xnvm_axim \
    $PD_SYSTOP_path/bready_cvm_axim \
    $PD_SYSTOP_path/rready_cvm_axim \
    $PD_SYSTOP_path/bready_expmstr0_axim \
    $PD_SYSTOP_path/rready_expmstr0_axim \
    $PD_SYSTOP_path/bready_expmstr1_axim \
    $PD_SYSTOP_path/rready_expmstr1_axim \
    $PD_SYSTOP_path/bready_ocvm_axim \
    $PD_SYSTOP_path/rready_ocvm_axim \
    $PD_SYSTOP_path/aclk_qreqn\[14\] \
    $PD_SYSTOP_path/aclk_qreqn\[13\] \
    $PD_SYSTOP_path/aclk_qreqn\[12\] \
    $PD_SYSTOP_path/aclk_qreqn\[11\] \
    $PD_SYSTOP_path/aclk_qreqn\[10\] \
    $PD_SYSTOP_path/aclk_qreqn\[9\] \
    $PD_SYSTOP_path/aclk_qreqn\[8\] \
    $PD_SYSTOP_path/aclk_qreqn\[7\] \
    $PD_SYSTOP_path/aclk_qreqn\[6\] \
    $PD_SYSTOP_path/aclk_qreqn\[5\] \
    $PD_SYSTOP_path/aclk_qreqn\[4\] \
    $PD_SYSTOP_path/aclk_qreqn\[3\] \
    $PD_SYSTOP_path/aclk_qreqn\[2\] \
    $PD_SYSTOP_path/aclk_qreqn\[1\] \
    $PD_SYSTOP_path/aclk_qreqn\[0\] \
]

# Clamp high for CPU PCSM signals to power switch controls
lappend PD_SYSTOP_ClampHigh $PD_SYSTOP_path/LP_CPU0_lgcpwrn_o
lappend PD_SYSTOP_ClampHigh $PD_SYSTOP_path/LP_CPU1_lgcpwrn_o
lappend PD_SYSTOP_ClampHigh $PD_SYSTOP_path/LP_CPU2_lgcpwrn_o
lappend PD_SYSTOP_ClampHigh $PD_SYSTOP_path/LP_CPU3_lgcpwrn_o

# Clamp high for CPU PCSM signals via CLUSTOP ports
set PD_SYSTOP_CPU_PCSMs_ClampHigh [list \
    $PD_CLUSTOP_path/LP_CPU0_lgcpwrn_i \
    $PD_CLUSTOP_path/LP_CPU0_lgcretn_i \
    $PD_CLUSTOP_path/LP_CPU0_rampwrn_i \
    $PD_CLUSTOP_path/LP_CPU0_ramretn_i \
    $PD_CLUSTOP_path/LP_CPU1_lgcpwrn_i \
    $PD_CLUSTOP_path/LP_CPU1_lgcretn_i \
    $PD_CLUSTOP_path/LP_CPU1_rampwrn_i \
    $PD_CLUSTOP_path/LP_CPU1_ramretn_i \
    $PD_CLUSTOP_path/LP_CPU2_lgcpwrn_i \
    $PD_CLUSTOP_path/LP_CPU2_lgcretn_i \
    $PD_CLUSTOP_path/LP_CPU2_rampwrn_i \
    $PD_CLUSTOP_path/LP_CPU2_ramretn_i \
    $PD_CLUSTOP_path/LP_CPU3_lgcpwrn_i \
    $PD_CLUSTOP_path/LP_CPU3_lgcretn_i \
    $PD_CLUSTOP_path/LP_CPU3_rampwrn_i \
    $PD_CLUSTOP_path/LP_CPU3_ramretn_i \
]

