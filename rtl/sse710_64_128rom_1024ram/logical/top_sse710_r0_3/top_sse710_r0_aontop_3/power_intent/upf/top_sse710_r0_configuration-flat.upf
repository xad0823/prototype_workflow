#-------------------------------------------------------------------------------
# Power State updates
#-------------------------------------------------------------------------------

if { $::env(QUESTA_PA) == 1 } {
    add_power_state PD_SYSTOP.primary -update \
        -state ON  {-logic_expr {LP_LPWRNSYSTOP==0}} \
        -state OFF {-logic_expr {LP_LPWRNSYSTOP==1}}

    add_power_state PD_CLUSTOP.primary -update \
        -state ON  {-logic_expr {LP_LPWRNCLUSTOP==0}} \
        -state OFF {-logic_expr {LP_LPWRNCLUSTOP==1}}

    add_power_state PD_CLUSTOP.ram_p -update \
        -state ON  [subst {-logic_expr {$PD_SYSTOP_path/LP_RPWRNCLUSTOP==0}}] \
        -state OFF [subst {-logic_expr {$PD_SYSTOP_path/LP_RPWRNCLUSTOP==1}}]

    add_power_state PD_CLUSTOP.ram_c -update \
        -state ON  [subst {-logic_expr {$PD_SYSTOP_path/LP_RPWRNCLUSTOP==0 || $PD_SYSTOP_path/LP_RRETNCLUSTOP==0}}] \
        -state OFF [subst {-logic_expr {$PD_SYSTOP_path/LP_RPWRNCLUSTOP==1 && $PD_SYSTOP_path/LP_RRETNCLUSTOP==1}}]

    add_power_state PD_EXTSYS0TOP.primary -update \
        -state ON  {-logic_expr {LP_LPWRNEXTSYS0TOP==0}} \
        -state OFF {-logic_expr {LP_LPWRNEXTSYS0TOP==1}}

    add_power_state PD_EXTSYS1TOP.primary -update \
        -state ON  {-logic_expr {LP_LPWRNEXTSYS1TOP==0}} \
        -state OFF {-logic_expr {LP_LPWRNEXTSYS1TOP==1}}

    add_power_state PD_DBGTOP.primary -update \
        -state ON  {-logic_expr {LP_LPWRNDBGTOP==0}} \
        -state OFF {-logic_expr {LP_LPWRNDBGTOP==1}}

    add_power_state PD_SECENCTOP.primary -update \
        -state ON  {-logic_expr {LP_LPWRNSECENCTOP==0}} \
        -state OFF {-logic_expr {LP_LPWRNSECENCTOP==1}}

    add_power_state PD_SECENCTOP.ram_p -update \
        -state ON  [subst {-logic_expr {LP_RPWRNSECENCTOP==0}}] \
        -state OFF [subst {-logic_expr {LP_RPWRNSECENCTOP==1}}]

    add_power_state PD_SECENCTOP.ram_c -update \
        -state ON  [subst {-logic_expr {LP_RPWRNSECENCTOP==0 || LP_RRETNSECENCTOP==0}}] \
        -state OFF [subst {-logic_expr {LP_RPWRNSECENCTOP==1 && LP_RRETNSECENCTOP==1}}]

    add_power_state PD_CPU0.primary -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU0_lgcpwrn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU0_lgcpwrn_i==1}}]

    add_power_state PD_CPU0.ram_p -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU0_rampwrn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU0_rampwrn_i==1}}]

    add_power_state PD_CPU0.ram_c -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU0_rampwrn_i==0 || $PD_CLUSTOP_path/LP_CPU0_ramretn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU0_rampwrn_i==1 && $PD_CLUSTOP_path/LP_CPU0_ramretn_i==1}}]

    add_power_state PD_CPU0.ret -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU0_lgcretn_i==0 || $PD_CLUSTOP_path/LP_CPU0_lgcretn_i==1}}]

    add_power_state PD_CPU1.primary -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU1_lgcpwrn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU1_lgcpwrn_i==1}}]

    add_power_state PD_CPU1.ram_p -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU1_rampwrn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU1_rampwrn_i==1}}]

    add_power_state PD_CPU1.ram_c -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU1_rampwrn_i==0 || $PD_CLUSTOP_path/LP_CPU1_ramretn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU1_rampwrn_i==1 && $PD_CLUSTOP_path/LP_CPU1_ramretn_i==1}}]

    add_power_state PD_CPU1.ret -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU1_lgcretn_i==0 || $PD_CLUSTOP_path/LP_CPU1_lgcretn_i==1}}]

    add_power_state PD_CPU2.primary -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU2_lgcpwrn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU2_lgcpwrn_i==1}}]

    add_power_state PD_CPU2.ram_p -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU2_rampwrn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU2_rampwrn_i==1}}]

    add_power_state PD_CPU2.ram_c -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU2_rampwrn_i==0 || $PD_CLUSTOP_path/LP_CPU2_ramretn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU2_rampwrn_i==1 && $PD_CLUSTOP_path/LP_CPU2_ramretn_i==1}}]

    add_power_state PD_CPU2.ret -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU2_lgcretn_i==0 || $PD_CLUSTOP_path/LP_CPU2_lgcretn_i==1}}]

    add_power_state PD_CPU3.primary -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU3_lgcpwrn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU3_lgcpwrn_i==1}}]

    add_power_state PD_CPU3.ram_p -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU3_rampwrn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU3_rampwrn_i==1}}]

    add_power_state PD_CPU3.ram_c -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU3_rampwrn_i==0 || $PD_CLUSTOP_path/LP_CPU3_ramretn_i==0}}] \
        -state OFF [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU3_rampwrn_i==1 && $PD_CLUSTOP_path/LP_CPU3_ramretn_i==1}}]

    add_power_state PD_CPU3.ret -update \
        -state ON  [subst {-logic_expr {$PD_CLUSTOP_path/LP_CPU3_lgcretn_i==0 || $PD_CLUSTOP_path/LP_CPU3_lgcretn_i==1}}]

}

puts ""
puts "###########################################################################"
puts "# Finished sse710_top configuration UPF"
puts "###########################################################################"
