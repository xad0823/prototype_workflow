set rules($iso-isolation_signal) $PD_CPU3_ppu_path/devemuisolaten_o
set rules($iso-isolation_sense) low


# Tcl to apply isolation rules, dropping empty exclude_elements and skipping rules those for which no elements have been identified
# This helper makes it much easier to specify the clamp rules in a way that avoids overlap (resolution by UPF precedence rules)

foreach key [lsort [array names rules *-domain]] {
  set iso [regsub {[-]domain$} $key ""]
  set cmd "set_isolation $iso"
  if {[info exists rules($iso-exclude_elements)] && [llength $rules($iso-exclude_elements)]==0} {
    array unset rules $iso-exclude_elements
  } 
  if {[info exists rules($iso-elements)] && [llength $rules($iso-elements)]==0} {
    puts "UPF_INFO: Isolation rule $iso skipped, no applicable elements"
  } else {
    if {[info exists rules($iso-elements)]} {
      append cmd " \\\n  -elements \{[join $rules($iso-elements) " "]\}"
    }
    array unset rules $iso-elements
    foreach iso_option [lsort [array names rules $iso-*]] {
      if {[llength $rules($iso_option)]>1} {
        append cmd " \\\n  [regsub "^$iso" $iso_option ""] \{[join $rules($iso_option) " "]\}"
      } else {
        append cmd " \\\n  [regsub "^$iso" $iso_option ""] $rules($iso_option)"
      }
    }
    #puts "UPF_INFO: $cmd"
    eval $cmd
  }
}
array unset rules

#-------------------------------------------------------------------------------
# Retention Strategy
#-------------------------------------------------------------------------------
set_retention ret_SECENCTOP_mem \
    -domain PD_SECENCTOP \
    -elements $PD_SECENCTOP_mem \
    -retention_supply_set PD_SECENCTOP.ram_c \
    -save_signal [list $PD_SECENCTOP_pcsm_path/ramretn_o negedge] \
    -restore_signal [list $PD_SECENCTOP_pcsm_path/ramretn_o posedge] 
    
set_retention ret_CLUSTOP_mem \
    -domain PD_CLUSTOP \
    -elements $PD_CLUSTOP_mem \
    -retention_supply_set PD_CLUSTOP.ram_c \
    -save_signal [list $PD_CLUSTOP_pcsm_path/ramretn_o negedge] \
    -restore_signal [list $PD_CLUSTOP_pcsm_path/ramretn_o posedge] 

set_retention ret_CPU0 \
    -domain PD_CPU0 \
    -elements $PD_CPU0_path \
    -retention_supply_set PD_CPU0.ret \
    -save_signal [list $PD_CLUSTOP_path/LP_CPU0_lgcretn_i negedge] \
    -restore_signal [list $PD_CLUSTOP_path/LP_CPU0_lgcretn_i posedge] 
    
