array set rules [list]


set iso "iso_PD_SYSTOP_Low"
set rules($iso-domain) PD_SYSTOP
set rules($iso-applies_to) outputs
set rules($iso-clamp_value) 0
set rules($iso-isolation_signal) $PD_SYSTOP_ppu_path/devemuisolaten_o
set rules($iso-isolation_sense) low
set rules($iso-source) PD_SYSTOP.primary
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~NOTE~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# Include the variable $PD_SYSTOP_iso_exclude in the below list while in system context.
# Follow guidance in the parent UPF to define this variable.
# It is necessary to exclude these signals from isolation cell insertion 
# for correct system functionality.
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
set rules($iso-exclude_elements) [concat \
                                   $PD_SYSTOP_ClampHigh \
                                   $PD_SYSTOP_CPU_PCSMs_ClampLow \
