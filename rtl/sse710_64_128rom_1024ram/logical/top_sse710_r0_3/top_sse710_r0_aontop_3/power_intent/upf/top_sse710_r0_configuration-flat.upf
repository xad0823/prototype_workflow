#-------------------------------------------------------------------------------
# RAM connections
#-------------------------------------------------------------------------------
set memPorts             [ list PGEN RET1N RET2N VDDPE VDDCE VSSE VSS VDDE]
set memories [list \
    PD_AON           [list memories $PD_AON_mem] \
    PD_SECENCTOP     [list memories $PD_SECENCTOP_mem] \
    PD_SECENCTOP_rom [list memories $PD_SECENCTOP_rom] \
    PD_CLUSTOP       [list memories $PD_CLUSTOP_mem] \
    PD_CPU0 [list memories $PD_CPU0_mem] \
    PD_CPU1 [list memories $PD_CPU1_mem] \
    PD_CPU2 [list memories $PD_CPU2_mem] \
    PD_CPU3 [list memories $PD_CPU3_mem] \
]

dict for {ram_type ram_info} $memories {
    foreach port $memPorts {
        set ports {}
        foreach memory [dict get $ram_info memories] {
            set ports [concat $ports $memory/$port]
        }
        set ${ram_type}_memports($port) $ports
    }
    set inputs {}
    set outputs {}
    foreach memory [dict get $ram_info memories] {
        set inputs  [concat $inputs  {*}[find_objects $memory -object_type port -direction in  -pattern *]]
        set outputs [concat $outputs {*}[find_objects $memory -object_type port -direction in  -pattern *]]
    }
    set ${ram_type}_memports(inputs) $inputs
    set ${ram_type}_memports(outputs) $inputs
}

proc relative_path {paths} {
    upvar current_scope prefix
    set relative_paths {}
    foreach path $paths {
        if {[string first $prefix $path] == 0} {
            lappend relative_paths [string range $path [string length $prefix]+1 end]
        } else {
            lappend relative_paths $path
        }
    }
    return $relative_paths
}

#-------------------------------------------------------------------------------
# LP Control signals
#-------------------------------------------------------------------------------
create_logic_net  LP_LPWRNSYSTOP
connect_logic_net LP_LPWRNSYSTOP        -ports $PD_SYSTOP_pcsm_path/lgcpwrn_o -reconnect

create_logic_net  LP_LPWRNCLUSTOP
connect_logic_net LP_LPWRNCLUSTOP       -ports $PD_CLUSTOP_pcsm_path/lgcpwrn_o -reconnect

create_logic_net  LP_RPWRNCLUSTOP
connect_logic_net LP_RPWRNCLUSTOP       -ports [concat $PD_CLUSTOP_pcsm_path/rampwrn_o $PD_CLUSTOP_memports(PGEN)] -reconnect

create_logic_net  LP_RRETNCLUSTOP
connect_logic_net LP_RRETNCLUSTOP       -ports [concat $PD_CLUSTOP_pcsm_path/ramretn_o $PD_CLUSTOP_memports(RET1N) $PD_CLUSTOP_memports(RET2N)] -reconnect

create_logic_net  LP_LPWRNSECENCTOP
connect_logic_net LP_LPWRNSECENCTOP     -ports $PD_SECENCTOP_pcsm_path/lgcpwrn_o -reconnect

create_logic_net  LP_RPWRNSECENCTOP
connect_logic_net LP_RPWRNSECENCTOP     -ports [concat $PD_SECENCTOP_pcsm_path/rampwrn_o $PD_SECENCTOP_memports(PGEN) $PD_SECENCTOP_rom_memports(PGEN)] -reconnect

create_logic_net  LP_RRETNSECENCTOP
connect_logic_net LP_RRETNSECENCTOP     -ports [concat $PD_SECENCTOP_pcsm_path/ramretn_o $PD_SECENCTOP_memports(RET1N) $PD_SECENCTOP_memports(RET2N)] -reconnect

create_logic_net  LP_LPWRNDBGTOP
connect_logic_net LP_LPWRNDBGTOP        -ports $PD_DBGTOP_pcsm_path/lgcpwrn_o -reconnect

