module firewall_f0_ram_wrapper
#(
    parameter                               DATA_WIDTH      =   32,
    parameter                               ADDR_WIDTH      =   11
)
(
    input   wire                            clk,
    input   wire    [ADDR_WIDTH-1:0]        a,
    input   wire                            cena,
    input   wire                            global_wena,
    output  wire    [DATA_WIDTH-1:0]        q,
    input   wire    [DATA_WIDTH-1:0]        d,
    input   wire                            DFTRAMBYP,
    input   wire                            DFTRAMHOLD
);


arm_element_sp_ram_pa
#(
    .DATA_WIDTH             (DATA_WIDTH          ),
    .MEMORY_DEPTH           (1 << ADDR_WIDTH     ),
    .ADDR_WIDTH             (ADDR_WIDTH          ),
    .LANE_WIDTH             (DATA_WIDTH          )
)
u_arm_element_sp_ram_pa
(
    .CLK                    (clk                 ),
    .RESETn                 (1'b1                ),
`ifdef ARM_PA_MODE_ENABLE
    .VDDCE                  (                    ),
    .VDDPE                  (                    ),
    .VSSE                   (                    ),
    .PGEN                   (                    ),
    .RET1N                  (                    ),
    .RET2N                  (                    ),
    .PRDYN                  (                    ),
`endif
    .A                      (a                   ),
    .CEN                    (~(cena & ~DFTRAMHOLD)),
    .WEN                    (~global_wena        ), 
    .Q                      (q                   ),
    .D                      (d                   )
);


endmodule
