# File: ReadMe_configurable_parameters
# =============================================================================
# Purpose :
#          Details the parameters for configuring an AMBA Domain bridge with 
#          BAS interfaces.
#
# =============================================================================


# Width of the AWADDR, ARADDR signals
# Range [32-64]
# Default 40
ADDR_WIDTH          = 40


# Width of the WDATA and RDATA signals
# Range [8,16,32,64,128,256,512,1024]
# Default 128
DATA_WIDTH          = 128
# Width of the AWID and BID signals
# Range [0-32]
# Default 1
AWID_WIDTH          = 1

# Width of the ARID and RID signals
# Range [0-32]
# Default 1
ARID_WIDTH          = 1

# Device AXI Channel User Widths
# Range [0-256]
# Default 1
AWUSER_WIDTH        = 1
WUSER_WIDTH         = 1 
BUSER_WIDTH         = 1
ARUSER_WIDTH        = 1
RUSER_WIDTH         = 1


# Number of stages in Synchronisers
# Range [2-4]
# Default 2
SI_SYNC_LEVELS      = 2
MI_SYNC_LEVELS      = 2


# Number of slots in the FIFO on each channel
# Range [2-10]
# Defaults:
AW_FIFO_DEPTH       = 4
W_FIFO_DEPTH        = 6
B_FIFO_DEPTH        = 2
AR_FIFO_DEPTH       = 4
R_FIFO_DEPTH        = 6

# Output Registering for Timing Closure 
# Range [0 - not present, 1- present]
AW_OPREG            = 1
W_OPREG             = 1
B_OPREG             = 1
AR_OPREG            = 1
R_OPREG             = 1
