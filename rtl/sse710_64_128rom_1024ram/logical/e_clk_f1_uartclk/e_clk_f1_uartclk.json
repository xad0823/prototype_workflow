{
   "package_dependency" : [
      "arm_element_tech_models",
      "clkrst_f1",
      "clkselNway_f0_3",
      "clkselNway_f0_2"
   ],
   "SUFFIX" : "_uartclk",
   "clocks" : {
      "HOSTUARTCLK" : {
         "clk_source" : [
            "REFCLK",
            "UARTCLK",
            "S32KCLK"
         ],
         "divider" : {
            "per_clk_divider" : {
               "UARTCLK" : {
                  "pipeline_depth" : "0",
                  "divider_type" : "divider"
               }
            }
         },
         "internal_clk" : "false",
         "rst_source" : "RESETN"
      }
   },
   "package_template" : "$ARM_IP_LIBRARY/e_clk_f1",
   "TEMPLATE_PKG_ID" : "e_clk_f1"
}
